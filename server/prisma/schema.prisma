generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== CMS ADMIN ====================

enum CmsAdminRole {
  SUPER_ADMIN
  EDITOR
  VIEWER
}

enum CmsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  REJECTED
}

// ==================== CMS ADMIN ====================

model CmsAdmin {
  id           String       @id @default(cuid())
  email        String       @unique
  passwordHash String
  name         String
  role         CmsAdminRole @default(VIEWER)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("cms_admins")
}

// ==================== CMS CATEGORY ====================

model CmsCategory {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  imageUrl      String?
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  subCategories CmsSubCategory[]
  blogs         CmsBlog[]
  products      CmsProduct[]
  leads         CmsLead[]
 

  @@map("cms_categories")
}

// ==================== CMS SUB CATEGORY ====================

model CmsSubCategory {
  id         String      @id @default(cuid())
  name       String
  slug       String      @unique
  imageUrl   String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  categoryId String
  category   CmsCategory @relation(fields: [categoryId], references: [id])
  blogs      CmsBlog[]
  products   CmsProduct[]

  @@index([categoryId])
  @@map("cms_sub_categories")
}

// ==================== CMS BLOG ====================

model CmsBlog {
  id             String          @id @default(cuid())
  title          String
  slug           String          @unique
  excerpt        String?
  content        String          @db.Text
  coverImage     String?
  tags           String[]        @default([])
  author         String?
  status         CmsStatus       @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?         @db.Text
  viewCount      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  categoryId    String?
  category      CmsCategory?    @relation(fields: [categoryId], references: [id])

  subCategoryId String?
  subCategory   CmsSubCategory? @relation(fields: [subCategoryId], references: [id])

  @@index([status])
  @@index([publishedAt])
  @@index([categoryId])
  @@map("cms_blogs")
}

// ==================== CMS PARTNER ====================

model CmsPartner {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_partners")
}

// ==================== CMS TESTIMONIAL ====================

model CmsTestimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  avatar    String?
  content   String   @db.Text
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_testimonials")
}

// ==================== CMS PRODUCT ====================

model CmsProduct {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  shortDescription String?
  description      String?         @db.Text
  image            String?

  // Provider
  provider         String?
  providerLogo     String?

  // Financial Details
  interestRate     String?
  processingFee    String?
  minAmount        String?
  maxAmount        String?
  tenure           String?

  // Rich Content
  features         Json?
  benefits         Json?
  eligibility      Json?
  formFields       Json?           // ← dynamic form fields

  // CTA
  applyUrl         String?

  // Flags
  status           CmsStatus       @default(DRAFT)
  featured         Boolean         @default(false)
  isBestSeller     Boolean         @default(false)
  badge            String?
  sortOrder        Int             @default(0)

  // SEO
  seoTitle         String?
  seoDescription   String?         @db.Text

  // Stats
  viewCount        Int             @default(0)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  categoryId       String?
  category         CmsCategory?    @relation(fields: [categoryId], references: [id])

  subCategoryId    String?
  subCategory      CmsSubCategory? @relation(fields: [subCategoryId], references: [id])

  leads            CmsLead[]

  @@index([status])
  @@index([featured])
  @@index([categoryId])
  @@map("cms_products")
}

// ==================== CMS LEAD ====================

model CmsLead {
  id          String      @id @default(cuid())
  name        String
  email       String?
  phone       String?
  message     String?     @db.Text
  customData  Json?       // ← dynamic fields data
  status      LeadStatus  @default(NEW)
  notes       String?     @db.Text
  assignedTo  String?
  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  productId   String?
  product     CmsProduct?  @relation(fields: [productId], references: [id])

  categoryId  String?
  category    CmsCategory? @relation(fields: [categoryId], references: [id])

  @@index([productId])
  @@index([status])
  @@index([categoryId])
  @@map("cms_leads")
}

// ==================== CMS AD ====================

enum AdPage {
  HOME
  BLOG
  BLOG_DETAIL      
  PRODUCT
  PRODUCT_DETAIL   
  CATEGORY
  SUB_CATEGORY     
  TOOLS            
  CALCULATOR
}

enum AdPosition {
  TOP
  BOTTOM
  BETWEEN_CONTENT
  SIDEBAR
}

enum AdSize {
  BANNER_728x90
  BANNER_300x250
  BANNER_300x600
  BANNER_320x50
  BANNER_160x600
  BANNER_970x90
  CUSTOM
}

enum AdEventType {
  CLICK
  IMPRESSION
}

model CmsAd {
  id            String       @id @default(cuid())
  title         String
  pages         AdPage[]
  positions     AdPosition[]
  customWidth   Int?
  customHeight  Int?
  size          AdSize       @default(BANNER_300x250)
  startDateTime DateTime?
  endDateTime   DateTime?
  link          String?
  image         String
  active        Boolean      @default(true)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  events        CmsAdEvent[]

  @@index([active])
  @@map("cms_ads")
}

// ==================== CMS AD EVENT ====================

model CmsAdEvent {
  id          String       @id @default(cuid())
  adId        String
  ad          CmsAd        @relation(fields: [adId], references: [id])
  type        AdEventType
  isUnique    Boolean      @default(false)
  ip          String?
  sessionId   String?
  userAgent   String?
  deviceType  String?
  page        String?
  referrer    String?
  country     String?
  createdAt   DateTime     @default(now())

  @@index([adId])
  @@index([type])
  @@index([isUnique])
  @@index([sessionId])
  @@index([createdAt])
  @@index([deviceType])
  @@map("cms_ad_events")
}